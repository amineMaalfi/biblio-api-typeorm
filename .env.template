PORT=3000
# SQLite file path (relative to process cwd or absolute)
DATABASE_FILE=biblio.sqlite

# Auth — change in production
JWT_SECRET=change-me-to-a-long-random-string

# First librarian created on startup if no librarian exists yet
LIBRARIAN_EMAIL=librarian@example.com
LIBRARIAN_PASSWORD=change-this-password
LIBRARIAN_FULL_NAME=Bibliothécaire

# Optional: allow creating librarian accounts via register body
LIBRARIAN_REGISTRATION_SECRET=

# Borrowing rules (JSON): extra fee in DH by loan duration (days)
DURATION_EXTRA_FEES_JSON={"7":0,"15":10,"30":20,"60":40,"90":60}
LATE_FEE_PER_DAY_DH=5
